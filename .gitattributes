# Fins de ligne : LF partout (dans le dépôt ET sur le disque).
# Évite les fichiers "modifiés" fantômes qui changent d'une machine à l'autre.
* text=auto eol=lf

# Scripts Windows : doivent rester en CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Fichiers binaires : ne jamais convertir
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.woff  binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.otf  binary
*.mp3  binary
*.wav  binary
*.ogg  binary
*.mp4  binary
*.webm binary
*.zip  binary
*.gz   binary
*.pdf  binary
